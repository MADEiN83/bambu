{
  "name": "@crazydev/bambu",
  "version": "0.0.0",
  "description": "Unofficial Bambu Lab SDK for Node.js — Cloud REST + LAN MQTT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cloud": {
      "types": "./dist/cloud/index.d.ts",
      "import": "./dist/cloud/index.js"
    },
    "./lan": {
      "types": "./dist/lan/index.d.ts",
      "import": "./dist/lan/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "keywords": [
    "bambu",
    "bambulab",
    "3d-printing",
    "mqtt",
    "x1c",
    "p1s",
    "sdk",
    "typescript"
  ],
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target node --format esm && tsc --emitDeclarationOnly --outDir dist",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "mqtt": "^5.10.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MADEiN83/bambu.git",
    "directory": "packages/sdk"
  },
  "license": "MIT",
  "author": "Anthony Di Stefano"
}
