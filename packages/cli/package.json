{
  "name": "@crazydev/bambu-cli",
  "version": "0.0.0",
  "description": "CLI for Bambu Lab printers — built on @crazydev/bambu",
  "type": "module",
  "bin": {
    "bbu": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "bambu",
    "bambulab",
    "cli",
    "3d-printing"
  ],
  "scripts": {
    "build": "bun build ./src/cli.ts --outdir ./dist --target node --format esm && tsc --emitDeclarationOnly --outDir dist",
    "build:bin": "bun build ./src/cli.ts --compile --outfile ./dist/bbu",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@crazydev/bambu": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MADEiN83/bambu.git",
    "directory": "packages/cli"
  },
  "license": "MIT",
  "author": "Anthony Di Stefano"
}
