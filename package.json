{
  "name": "bambu-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Unofficial Bambu Lab SDK & CLI for Node.js — monorepo",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter '*' build",
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bun test",
    "lint": "biome check .",
    "format": "biome format --write .",
    "try": "bun examples/cloud-test.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/bun": "latest",
    "typescript": "^5.6.0"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
